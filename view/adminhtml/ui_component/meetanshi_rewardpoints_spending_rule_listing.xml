<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">meetanshi_rewardpoints_spending_rule_listing.meetanshi_rewardpoints_spending_rule_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Rule</label>
            </button>
        </buttons>
        <spinner>meetanshi_rewardpoints_spending_rule_columns</spinner>
        <deps>
            <dep>meetanshi_rewardpoints_spending_rule_listing.meetanshi_rewardpoints_spending_rule_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="meetanshi_rewardpoints_spending_rule_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">rule_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Meetanshi_RewardPoints::spending_rule</aclResource>
        <dataProvider class="Meetanshi\RewardPoints\Ui\DataProvider\SpendingRule\ListingDataProvider"
                      name="meetanshi_rewardpoints_spending_rule_listing_data_source">
            <settings>
                <requestFieldName>rule_id</requestFieldName>
                <primaryFieldName>rule_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected spending rules?</message>
                        <title translate="true">Delete Spending Rules</title>
                    </confirm>
                    <url path="meetanshi_rewardpoints/spendingrule/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
            <action name="enable">
                <settings>
                    <url path="meetanshi_rewardpoints/spendingrule/massStatus">
                        <param name="status">1</param>
                    </url>
                    <type>enable</type>
                    <label translate="true">Enable</label>
                </settings>
            </action>
            <action name="disable">
                <settings>
                    <url path="meetanshi_rewardpoints/spendingrule/massStatus">
                        <param name="status">0</param>
                    </url>
                    <type>disable</type>
                    <label translate="true">Disable</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="meetanshi_rewardpoints_spending_rule_columns">
        <settings>
            <editorConfig>
                <param name="selectProvider" xsi:type="string">meetanshi_rewardpoints_spending_rule_listing.meetanshi_rewardpoints_spending_rule_listing.meetanshi_rewardpoints_spending_rule_columns.ids</param>
                <param name="enabled" xsi:type="boolean">true</param>
                <param name="indexField" xsi:type="string">rule_id</param>
            </editorConfig>
            <childDefaults>
                <param name="fieldAction" xsi:type="array">
                    <item name="provider" xsi:type="string">meetanshi_rewardpoints_spending_rule_listing.meetanshi_rewardpoints_spending_rule_listing.meetanshi_rewardpoints_spending_rule_columns_editor</item>
                    <item name="target" xsi:type="string">startEdit</item>
                    <item name="params" xsi:type="array">
                        <item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
                        <item name="1" xsi:type="boolean">true</item>
                    </item>
                </param>
            </childDefaults>
        </settings>
        <selectionsColumn name="ids">
            <settings>
                <indexField>rule_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="rule_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <editor>
                    <validation>
                        <rule name="required-entry" xsi:type="boolean">true</rule>
                    </validation>
                    <editorType>text</editorType>
                </editor>
                <label translate="true">Rule Name</label>
            </settings>
        </column>
        <column name="is_active" component="Meetanshi_RewardPoints/js/grid/columns/status">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter>
                <editor>
                    <editorType>select</editorType>
                </editor>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="spending_style" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Meetanshi\RewardPoints\Model\Source\SpendingStyle"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Spending Style</label>
            </settings>
        </column>
        <column name="discount_action" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Meetanshi\RewardPoints\Model\Source\DiscountAction"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Discount Action</label>
            </settings>
        </column>
        <column name="discount_amount">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Discount Amount</label>
            </settings>
        </column>
        <column name="min_points">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Min Points</label>
            </settings>
        </column>
        <column name="max_points">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Max Points (0=Unlimited)</label>
            </settings>
        </column>
        <column name="priority">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Priority</label>
            </settings>
        </column>
        <column name="websites">
            <settings>
                <options class="Meetanshi\RewardPoints\Model\Source\WebsiteFilter"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Websites</label>
            </settings>
        </column>
        <column name="customer_groups">
            <settings>
                <options class="Meetanshi\RewardPoints\Model\Source\CustomerGroupFilter"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Customer Groups</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Meetanshi\RewardPoints\Ui\Component\Listing\SpendingRule\Column\Actions">
            <settings>
                <indexField>rule_id</indexField>
                <label translate="true">Actions</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
