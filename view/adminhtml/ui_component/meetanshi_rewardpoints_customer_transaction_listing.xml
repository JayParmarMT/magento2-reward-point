<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">meetanshi_rewardpoints_customer_transaction_listing.meetanshi_rewardpoints_customer_transaction_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <buttons/>
        <spinner>meetanshi_rewardpoints_customer_transaction_listing_columns</spinner>
        <deps>
            <dep>meetanshi_rewardpoints_customer_transaction_listing.meetanshi_rewardpoints_customer_transaction_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="meetanshi_rewardpoints_customer_transaction_listing_data_source"
                component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">transaction_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Meetanshi_RewardPoints::transactions</aclResource>
        <dataProvider
            class="Meetanshi\RewardPoints\Ui\DataProvider\Customer\TransactionListingDataProvider"
            name="meetanshi_rewardpoints_customer_transaction_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>transaction_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>false</sticky>
        </settings>
        <paging name="listing_paging"/>
        <filters name="listing_filters">
            <settings>
                <statefull>
                    <property name="applied" xsi:type="boolean">false</property>
                </statefull>
            </settings>
        </filters>
    </listingToolbar>

    <columns name="meetanshi_rewardpoints_customer_transaction_listing_columns">
        <settings>
            <childDefaults>
                <param name="fieldAction" xsi:type="array">
                    <item name="provider" xsi:type="string">meetanshi_rewardpoints_customer_transaction_listing.meetanshi_rewardpoints_customer_transaction_listing.meetanshi_rewardpoints_customer_transaction_listing_columns</item>
                    <item name="target" xsi:type="string">applyAction</item>
                    <item name="params" xsi:type="array">
                        <item name="0" xsi:type="string">view</item>
                        <item name="1" xsi:type="string">${ $.$data.rowIndex }</item>
                    </item>
                </param>
            </childDefaults>
        </settings>

        <column name="transaction_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <column name="action_code">
            <settings>
                <filter>text</filter>
                <label translate="true">Action</label>
            </settings>
        </column>

        <column name="points_delta">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Points</label>
            </settings>
        </column>

        <column name="points_balance_after">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Balance After</label>
            </settings>
        </column>

        <column name="status">
            <settings>
                <filter>text</filter>
                <label translate="true">Status</label>
            </settings>
        </column>

        <column name="expires_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Expires At</label>
                <timezone>false</timezone>
                <dateFormat>MMM d, y</dateFormat>
            </settings>
        </column>

        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Created At</label>
                <timezone>false</timezone>
                <dateFormat>MMM d, y, h:mm a</dateFormat>
                <sorting>desc</sorting>
            </settings>
        </column>

        <column name="comment">
            <settings>
                <filter>text</filter>
                <label translate="true">Comment</label>
            </settings>
        </column>

        <column name="order_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Order ID</label>
            </settings>
        </column>

    </columns>
</listing>
