$reportType   = $block->getData('report_type');
$period       = $block->getRequest()->getParam('period', 'day');
$chartData    = $block->getChartData($period);
$isEarned     = ($reportType === 'earned');
$total        = $isEarned ? $block->getTotalEarned() : $block->getTotalSpent();
$accentColor  = $isEarned ? '#1979c3' : '#e22626';
$accentLight  = $isEarned ? 'rgba(25,121,195,0.15)' : 'rgba(226,38,38,0.15)';
$accentBorder = $isEarned ? 'rgba(25,121,195,0.9)'  : 'rgba(226,38,38,0.9)';
$chartLabel   = $isEarned ? __('Points Earned') : __('Points Spent');
$icon         = $isEarned ? '⬆' : '⬇';

$periodLabels = ['day' => __('Day'), 'week' => __('Week'), 'month' => __('Month')];
$avgPoints    = count($chartData) > 0 ? (int) round($total / count($chartData)) : 0;
$peakRow      = !empty($chartData)
    ? array_reduce($chartData, fn($c, $r) => ($r['points'] > ($c['points'] ?? 0)) ? $r : $c, [])
    : null;
