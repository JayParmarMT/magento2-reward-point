<?php if (!empty($chartData)): ?>
<script>
require(['jquery'], function ($) {
    'use strict';

    var RAW         = <?= /* @noEscape */ json_encode(array_values($chartData)) ?>;
    var FILL_COLOR  = '<?= $escaper->escapeJs($accentLight) ?>';
    var BAR_COLOR   = '<?= $escaper->escapeJs($accentBorder) ?>';
    var labels      = RAW.map(function(r){ return r.date; });
    var values      = RAW.map(function(r){ return parseInt(r.points, 10); });
    var maxVal      = Math.max.apply(null, values) || 1;

    var canvas      = document.getElementById('rpChart');
    if (!canvas) { return; }

    var DPR    = window.devicePixelRatio || 1;
    var W      = canvas.parentElement.clientWidth || 800;
    var H      = 300;
    var PAD    = { top: 24, right: 20, bottom: 52, left: 64 };
    var PLOT_W = W - PAD.left - PAD.right;
    var PLOT_H = H - PAD.top - PAD.bottom;
    var RADIUS = 4;
    var N      = values.length;

    canvas.width  = W * DPR;
    canvas.height = H * DPR;
    canvas.style.height = H + 'px';

    var ctx = canvas.getContext('2d');
    ctx.scale(DPR, DPR);

    /* ── helpers ── */
    function yPos(v) { return PAD.top + PLOT_H - (v / maxVal) * PLOT_H; }
    function xPos(i) { return PAD.left + (i + 0.5) * (PLOT_W / N); }

    function niceMax(v) {
        var exp = Math.pow(10, Math.floor(Math.log10(v || 1)));
        return Math.ceil(v / exp) * exp;
    }

    function fmtNum(v) {
        if (v >= 1000000) return (v / 1000000).toFixed(1) + 'M';
        if (v >= 1000)    return (v / 1000).toFixed(1) + 'k';
        return v.toString();
    }

    var nMax    = niceMax(maxVal);
    var GRID_N  = 5;
    var barW    = Math.max(4, Math.min(40, PLOT_W / N - 6));

    /* ── background ── */
    ctx.fillStyle = '#fff';
    ctx.fillRect(0, 0, W, H);

    /* ── grid lines + Y labels ── */
    ctx.textAlign    = 'right';
    ctx.textBaseline = 'middle';
    ctx.font         = '11px -apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif';

    for (var g = 0; g <= GRID_N; g++) {
        var gv  = (nMax / GRID_N) * g;
        var gy  = PAD.top + PLOT_H - (gv / nMax) * PLOT_H;

        ctx.strokeStyle = g === 0 ? '#ccc' : '#ececec';
        ctx.lineWidth   = g === 0 ? 1.5 : 1;
        ctx.beginPath();
        ctx.moveTo(PAD.left, gy);
        ctx.lineTo(PAD.left + PLOT_W, gy);
        ctx.stroke();

        ctx.fillStyle = '#999';
        ctx.fillText(fmtNum(Math.round(gv)), PAD.left - 8, gy);
    }

    /* ── bars with rounded tops ── */
    values.forEach(function (v, i) {
        var x  = xPos(i) - barW / 2;
        var bh = Math.max(2, (v / nMax) * PLOT_H);
        var y  = PAD.top + PLOT_H - bh;

        ctx.fillStyle = FILL_COLOR;
        ctx.beginPath();
        ctx.moveTo(x + RADIUS, y);
        ctx.lineTo(x + barW - RADIUS, y);
        ctx.quadraticCurveTo(x + barW, y, x + barW, y + RADIUS);
        ctx.lineTo(x + barW, y + bh);
        ctx.lineTo(x, y + bh);
        ctx.lineTo(x, y + RADIUS);
        ctx.quadraticCurveTo(x, y, x + RADIUS, y);
        ctx.closePath();
        ctx.fill();

        ctx.strokeStyle = BAR_COLOR;
        ctx.lineWidth   = 1.5;
        ctx.stroke();
    });

    /* ── X axis labels (show up to 12, evenly spaced) ── */
    var step = Math.max(1, Math.ceil(N / 12));
    ctx.fillStyle    = '#888';
    ctx.textAlign    = 'center';
    ctx.textBaseline = 'top';
    ctx.font         = '10px -apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif';

    labels.forEach(function (lbl, i) {
        if (i % step !== 0 && i !== N - 1) { return; }
        var x = xPos(i);
        ctx.save();
        ctx.translate(x, PAD.top + PLOT_H + 8);
        ctx.rotate(-0.45);
        ctx.fillText(lbl, 0, 0);
        ctx.restore();
    });

    /* ── tooltip on hover ── */
    var tooltip = document.getElementById('rpChartTooltip');
    var rect;

    canvas.addEventListener('mousemove', function (e) {
        rect = canvas.getBoundingClientRect();
        var mx = (e.clientX - rect.left);
        var my = (e.clientY - rect.top);

        var hit = -1;
        values.forEach(function (v, i) {
            var x  = xPos(i) - barW / 2;
            var bh = Math.max(2, (v / nMax) * PLOT_H);
            var y  = PAD.top + PLOT_H - bh;
            if (mx >= x && mx <= x + barW && my >= y && my <= PAD.top + PLOT_H) {
                hit = i;
            }
        });

        if (hit >= 0) {
            tooltip.style.display = 'block';
            tooltip.style.left    = (e.clientX + 12) + 'px';
            tooltip.style.top     = (e.clientY - 28) + 'px';
            tooltip.textContent   = labels[hit] + ' — ' + values[hit].toLocaleString() + ' pts';
            canvas.style.cursor   = 'crosshair';
        } else {
            tooltip.style.display = 'none';
            canvas.style.cursor   = 'default';
        }
    });

    canvas.addEventListener('mouseleave', function () {
        tooltip.style.display = 'none';
    });

    /* ── redraw on resize ── */
    var resizeTimer;
    window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
            W       = canvas.parentElement.clientWidth || 800;
            PLOT_W  = W - PAD.left - PAD.right;
            canvas.width        = W * DPR;
            canvas.style.width  = W + 'px';
            ctx.scale(DPR, DPR);
            // re-run draw by reloading — simple and reliable
            window.location.reload();
        }, 400);
    });
});
</script>
<?php endif; ?>
