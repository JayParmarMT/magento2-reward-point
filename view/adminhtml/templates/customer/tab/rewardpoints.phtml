<script type="text/javascript">
require(['jquery', 'mage/translate'], function ($, $t) {
    'use strict';

    $('#rp_balance_save_btn').on('click', function () {
        var $btn    = $(this);
        var $form   = $('#reward-points-balance-form');
        var $msg    = $('#rp-balance-message');
        var points  = parseInt($('#rp_update_points').val(), 10);

        if (!points || isNaN(points) || points === 0) {
            $msg.html('<div class="message message-error">' +
                $t('Please enter a non-zero integer for points adjustment.') +
                '</div>').show();
            return;
        }

        $.ajax({
            url:      $form.attr('action'),
            type:     'POST',
            data:     $form.serialize(),
            dataType: 'json',
            beforeSend: function () {
                $btn.prop('disabled', true).text($t('Saving…'));
                $msg.hide();
            },
            success: function (response) {
                if (response.error) {
                    $msg.html('<div class="message message-error">' +
                        $('<div>').text(response.message).html() +
                        '</div>').show();
                } else {
                    $msg.html('<div class="message message-success">' +
                        $('<div>').text(response.message).html() +
                        '</div>').show();
                    $form[0].reset();
                }
            },
            error: function () {
                $msg.html('<div class="message message-error">' +
                    $t('An error occurred. Please try again.') +
                    '</div>').show();
            },
            complete: function () {
                $btn.prop('disabled', false).text($t('Update Balance'));
            }
        });
    });
});
</script>
