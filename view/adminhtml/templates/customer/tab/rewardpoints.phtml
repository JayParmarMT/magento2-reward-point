<script type="text/javascript">
(function () {
    'use strict';

    var BASE_URL = '<?= /* @noEscape */ $block->getUrl(
        'meetanshi_rewardpoints/customer/transactions',
        ['id' => $customerId, '_current' => false]
    ) ?>';

    var state = { page: 1, sort: 'created_at', dir: 'DESC', q: '' };

    function esc(v) {
        if (v === null || v === undefined) return '—';
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(String(v)));
        return d.innerHTML;
    }

    function deltaHtml(v) {
        var n = parseInt(v, 10) || 0;
        var cls = n >= 0 ? 'rp-delta-positive' : 'rp-delta-negative';
        var txt = (n >= 0 ? '+' : '') + n;
        return '<span class="' + cls + '">' + esc(txt) + '</span>';
    }

    function statusHtml(v) {
        var s = String(v || '').toLowerCase();
        var cls = s === 'active' ? 'rp-status-active'
                : s === 'expired' ? 'rp-status-expired'
                : s === 'cancelled' ? 'rp-status-cancelled'
                : 'rp-status-active';
        return '<span class="rp-status-badge ' + cls + '">'
             + esc(s.charAt(0).toUpperCase() + s.slice(1))
             + '</span>';
    }

    function sortIcon(col) {
        if (state.sort !== col) return ' <span style="color:#bbb;font-size:10px;">⇅</span>';
        return state.dir === 'ASC'
            ? ' <span style="font-size:10px;">▲</span>'
            : ' <span style="font-size:10px;">▼</span>';
    }

    function renderTable(data) {
        var wrap = document.getElementById('rp-txn-grid-wrap');
        if (data.error) {
            wrap.innerHTML = '<p style="padding:16px 20px;color:#e22626;">' + esc(data.message) + '</p>';
            return;
        }
        if (!data.rows || data.rows.length === 0) {
            wrap.innerHTML = '<p style="padding:16px 20px;color:#888;"><?= $escaper->escapeHtml(__('No transactions found.')) ?></p>';
            return;
        }

        var cols = [
            { key: 'transaction_id',     label: '#',            sort: true  },
            { key: 'action_code',        label: 'Action',       sort: true  },
            { key: 'points_delta',       label: 'Points',       sort: true  },
            { key: 'points_balance_after', label: 'Balance After', sort: true },
            { key: 'status',             label: 'Status',       sort: true  },
            { key: 'expires_at',         label: 'Expires At',   sort: true  },
            { key: 'created_at',         label: 'Created At',   sort: true  },
            { key: 'comment',            label: 'Comment',      sort: false },
            { key: 'order_id',           label: 'Order ID',     sort: false },
        ];

        var html = '<div style="overflow-x:auto;">'
                 + '<table class="rp-txn-table" style="width:100%;">'
                 + '<thead><tr>';

        cols.forEach(function (c) {
            html += '<th style="white-space:nowrap;cursor:' + (c.sort ? 'pointer' : 'default') + ';"'
                  + (c.sort ? ' data-sort="' + c.key + '"' : '') + '>'
                  + esc(c.label)
                  + (c.sort ? sortIcon(c.key) : '')
                  + '</th>';
        });
        html += '</tr></thead><tbody>';

        data.rows.forEach(function (row) {
            html += '<tr>';
            cols.forEach(function (c) {
                if (c.key === 'points_delta') {
                    html += '<td>' + deltaHtml(row[c.key]) + '</td>';
                } else if (c.key === 'status') {
                    html += '<td>' + statusHtml(row[c.key]) + '</td>';
                } else {
                    html += '<td>' + esc(row[c.key]) + '</td>';
                }
            });
            html += '</tr>';
        });

        html += '</tbody></table></div>';

        // pagination
        html += '<div style="display:flex;align-items:center;gap:8px;padding:10px 16px;border-top:1px solid #e3e3e3;">';
        html += '<span style="font-size:12px;color:#666;"><?= $escaper->escapeHtml(__('Total')) ?>: <strong>' + data.total + '</strong></span>';
        html += '<span style="margin-left:auto;display:flex;gap:4px;">';
        for (var i = 1; i <= data.pages; i++) {
            var active = i === data.page ? 'background:#1979c3;color:#fff;' : 'background:#f5f5f5;color:#333;';
            html += '<button data-page="' + i + '" style="' + active + 'border:1px solid #ccc;padding:2px 8px;font-size:12px;cursor:pointer;border-radius:3px;">' + i + '</button>';
        }
        html += '</span></div>';

        wrap.innerHTML = html;

        // sort click
        wrap.querySelectorAll('th[data-sort]').forEach(function (th) {
            th.addEventListener('click', function () {
                var col = th.getAttribute('data-sort');
                if (state.sort === col) {
                    state.dir = state.dir === 'ASC' ? 'DESC' : 'ASC';
                } else {
                    state.sort = col;
                    state.dir  = 'DESC';
                }
                state.page = 1;
                load();
            });
        });

        // page click
        wrap.querySelectorAll('button[data-page]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                state.page = parseInt(btn.getAttribute('data-page'), 10);
                load();
            });
        });
    }

    function load() {
        var url = BASE_URL
                + '?sort=' + encodeURIComponent(state.sort)
                + '&dir='  + encodeURIComponent(state.dir)
                + '&p='    + state.page
                + '&q='    + encodeURIComponent(state.q);

        var wrap = document.getElementById('rp-txn-grid-wrap');
        wrap.style.opacity = '0.5';

        fetch(url, { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                wrap.style.opacity = '1';
                renderTable(data);
            })
            .catch(function () {
                wrap.style.opacity = '1';
                wrap.innerHTML = '<p style="padding:16px 20px;color:#e22626;"><?= $escaper->escapeHtml(__('Failed to load transactions.')) ?></p>';
            });
    }

    // search with debounce
    var searchTimer;
    document.getElementById('rp-txn-search').addEventListener('input', function () {
        clearTimeout(searchTimer);
        var val = this.value;
        searchTimer = setTimeout(function () {
            state.q    = val;
            state.page = 1;
            load();
        }, 350);
    });

    load();
}());
</script>
