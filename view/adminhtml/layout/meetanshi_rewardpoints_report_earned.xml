<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <block class="Meetanshi\RewardPoints\Block\Adminhtml\Report\Earned"
                   name="meetanshi_rewardpoints_report_earned"
                   template="Meetanshi_RewardPoints::report/chart.phtml">
                <arguments>
                    <argument name="report_type" xsi:type="string">earned</argument>
                    <argument name="report_title" xsi:type="string" translate="true">Points Earned Report</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
