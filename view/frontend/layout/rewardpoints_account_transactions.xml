<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      layout="2columns-left">
    <update handle="customer_account"/>
    <body>
        <referenceContainer name="content">
            <block class="Meetanshi\RewardPoints\Block\Frontend\Account\Transactions"
                   name="rewardpoints.account.transactions"
                   template="Meetanshi_RewardPoints::account/transactions.phtml"
                   cacheable="false">
                <arguments>
                    <argument name="view_model" xsi:type="object">Meetanshi\RewardPoints\ViewModel\Account\Transactions</argument>
                </arguments>
                <block class="Magento\Theme\Block\Html\Pager"
                       name="rewardpoints.account.transactions.pager"
                       as="pager"
                       template="Meetanshi_RewardPoints::account/pager.phtml">
                    <arguments>
                        <argument name="limit" xsi:type="number">20</argument>
                    </arguments>
                </block>
            </block>
        </referenceContainer>
    </body>
</page>
