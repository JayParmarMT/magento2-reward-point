<?xml version="1.0"?>
<!--
    Hyvä-specific account dashboard layout.
    Swaps both the dashboard and milestones templates to the Hyvä/Tailwind versions.
    Previously the dashboard swap was in the now-removed RewardPointsHyva module.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="rewardpoints.account.dashboard">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Meetanshi_RewardPoints::hyva/account/dashboard.phtml</argument>
            </action>
        </referenceBlock>
        <referenceBlock name="rewardpoints.account.milestones">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Meetanshi_RewardPoints::hyva/account/milestones.phtml</argument>
            </action>
        </referenceBlock>
    </body>
</page>
