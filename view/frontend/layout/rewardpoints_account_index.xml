<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      layout="2columns-left">
    <update handle="customer_account"/>
    <body>
        <referenceContainer name="content">
            <block class="Meetanshi\RewardPoints\Block\Frontend\Account\Dashboard"
                   name="rewardpoints.account.dashboard"
                   template="Meetanshi_RewardPoints::account/dashboard.phtml"
                   cacheable="false">
                <arguments>
                    <argument name="view_model" xsi:type="object">Meetanshi\RewardPoints\ViewModel\Account\Dashboard</argument>
                </arguments>
            </block>
            <block class="Meetanshi\RewardPoints\Block\Frontend\Account\Milestones"
                   name="rewardpoints.account.milestones"
                   template="Meetanshi_RewardPoints::account/milestones.phtml"
                   cacheable="false"
                   after="rewardpoints.account.dashboard"/>
        </referenceContainer>
    </body>
</page>
