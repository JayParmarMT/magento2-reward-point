<?php
/**
 * Hyvä Buy With Points product template.
 *
 * Replaces Luma version which used .action.buy-with-points.primary CSS class.
 * Uses Tailwind utility classes compatible with Hyvä.
 *
 * @var \Meetanshi\RewardPoints\Block\Frontend\Product\BuyWithPoints $block
 * @var \Magento\Framework\Escaper $escaper
 */

if (!$block->canBuyWithPoints()) {
    return;
}

$pointPrice = $block->getPointPrice();
$balance    = $block->getCustomerBalance();
$buyUrl     = $block->getBuyWithPointsUrl();
?>

<div class="buy-with-points-wrapper mt-4" id="buy-with-points-block">
    <p class="text-sm text-gray-600 mb-2">
        <?= $escaper->escapeHtml(__('Or buy with %1 points', $pointPrice)) ?>
        <span class="text-gray-400 text-xs ml-1">
            (<?= $escaper->escapeHtml(__('Your balance: %1 points', $balance)) ?>)
        </span>
    </p>
    <a href="<?= $escaper->escapeUrl($buyUrl) ?>"
       class="buy-with-points-btn inline-flex items-center justify-center px-5 py-2.5 rounded border border-blue-600 text-blue-600 text-sm font-semibold hover:bg-blue-600 hover:text-white transition-colors duration-200"
       title="<?= $escaper->escapeHtmlAttr(__('Buy with %1 points', $pointPrice)) ?>">
        <span><?= $escaper->escapeHtml(__('Buy with %1 points', $pointPrice)) ?></span>
    </a>
</div>
