<?php
/**
 * Hyvä account dashboard — Reward Points.
 * All Tailwind classes confirmed present in Hyva/default web/css/styles.css.
 *
 * @var \Meetanshi\RewardPoints\Block\Frontend\Account\Dashboard $block
 * @var \Magento\Framework\Escaper $escaper
 */

if (!$block->isEnabled()) {
    return;
}

$account      = $block->getAccount();
if (!$account) {
    return;
}

$balance      = $block->getBalance();
$totalEarned  = $block->getTotalEarned();
$totalSpent   = $block->getTotalSpent();
$currentTier  = $block->getCurrentTier();
$transactions = $block->getRecentTransactions();
$pointLabel   = $escaper->escapeHtml($balance === 1 ? $block->getPointLabel() : $block->getPointLabelPlural());

$viewModel  = $block->getData('view_model');
$showSocial = $viewModel
    && $viewModel->isSocialEnabledOnPage('account')
    && ($viewModel->isFacebookEnabled() || $viewModel->isTwitterEnabled() || $viewModel->isPinterestEnabled());
?>

<!-- Balance card -->
<div class="bg-primary text-on-primary rounded-lg px-6 py-6 mb-6 shadow-md">
    <p class="text-xs font-semibold uppercase tracking-widest mb-1 text-on-primary" style="opacity:.75">
        <?= $escaper->escapeHtml(__('Available Balance')) ?>
    </p>
    <p class="text-3xl font-bold mb-6">
        <?= /* @noEscape */ (int) $balance ?> <?= $pointLabel ?>
    </p>
    <div class="flex gap-8 flex-wrap border-t pt-4" style="border-color:rgba(255,255,255,.2)">
        <div>
            <span class="block text-xs mb-1 text-on-primary" style="opacity:.75">
                <?= $escaper->escapeHtml(__('Total Earned')) ?>
            </span>
            <span class="text-xl font-bold"><?= /* @noEscape */ (int) $totalEarned ?></span>
        </div>
        <div>
            <span class="block text-xs mb-1 text-on-primary" style="opacity:.75">
                <?= $escaper->escapeHtml(__('Total Spent')) ?>
            </span>
            <span class="text-xl font-bold"><?= /* @noEscape */ (int) $totalSpent ?></span>
        </div>
    </div>
</div>

<!-- Current tier -->
<?php if ($currentTier): ?>
<div class="flex items-center gap-4 flex-wrap bg-gray-100 border border-gray-200 rounded-lg px-4 py-3 mb-6 shadow-sm">
    <?php if ($currentTier->getImage()): ?>
    <img src="<?= $escaper->escapeUrl($block->getTierImageUrl($currentTier)) ?>"
         alt="<?= $escaper->escapeHtmlAttr($currentTier->getName()) ?>"
         class="w-10 h-10 h-auto shrink-0"/>
    <?php endif; ?>
    <span class="bg-blue-600 text-white text-xs font-bold uppercase tracking-wider px-3 py-2 rounded-full">
        <?= $escaper->escapeHtml(__('Tier')) ?>
    </span>
    <span class="font-bold text-gray-900"><?= $escaper->escapeHtml($currentTier->getName()) ?></span>
    <?php if ($currentTier->getEarningBonusPercent() > 0): ?>
    <span class="ml-auto text-sm font-semibold text-gray-700">
        +<?= (float) $currentTier->getEarningBonusPercent() ?>% <?= $escaper->escapeHtml(__('earning bonus')) ?>
    </span>
    <?php endif; ?>
</div>
<?php endif; ?>

<!-- Email notifications -->
<div class="bg-white border border-gray-200 rounded-lg px-4 py-4 mb-6 shadow-sm"
     x-data="{
         subscribedBalance: <?= /* @noEscape */ $account->isSubscribedBalance() ? 'true' : 'false' ?>,
         subscribedExpiration: <?= /* @noEscape */ $account->isSubscribedExpiration() ? 'true' : 'false' ?>,
         saving: false,
         saved: false,
         savePreferences() {
             this.saving = true;
             this.saved  = false;
             fetch('<?= $escaper->escapeJs($block->getUrl('rewardpoints/account/saveSettings')) ?>', {
                 method: 'POST',
                 headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                 body: 'is_subscribed_balance=' + (this.subscribedBalance ? 1 : 0)
                     + '&is_subscribed_expiration=' + (this.subscribedExpiration ? 1 : 0)
                     + '&form_key=' + (document.querySelector('[name=form_key]')?.value ?? ''),
             })
             .then(r => r.json())
             .then(() => { this.saved = true; })
             .finally(() => { this.saving = false; });
         }
     }">
    <h3 class="text-base font-semibold text-primary mb-3 pb-2 border-b border-gray-200">
        <?= $escaper->escapeHtml(__('Email Notifications')) ?>
    </h3>
    <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-700 mb-3">
        <input type="checkbox" class="form-checkbox cursor-pointer" id="rpd-bal"
               x-model="subscribedBalance" @change="savePreferences">
        <span><?= $escaper->escapeHtml(__('Notify me when my balance changes')) ?></span>
    </label>
    <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-700">
        <input type="checkbox" class="form-checkbox cursor-pointer" id="rpd-exp"
               x-model="subscribedExpiration" @change="savePreferences">
        <span><?= $escaper->escapeHtml(__('Remind me when points are about to expire')) ?></span>
    </label>
    <p x-show="saving" class="text-xs text-gray-500 mt-3"><?= $escaper->escapeHtml(__('Saving…')) ?></p>
    <p x-show="saved" x-transition class="text-xs text-primary font-semibold mt-3"><?= $escaper->escapeHtml(__('Preferences saved.')) ?></p>
</div>

<!-- Recent transactions -->
<div class="mb-6">
    <h3 class="text-base font-semibold text-primary mb-3 pb-2 border-b border-gray-200">
        <?= $escaper->escapeHtml(__('Recent Transactions')) ?>
    </h3>
    <?php if (empty($transactions)): ?>
    <p class="text-sm text-gray-500 py-4"><?= $escaper->escapeHtml(__('No transactions yet.')) ?></p>
    <?php else: ?>
    <div class="overflow-x-auto rounded-lg border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-container-darker">
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider whitespace-nowrap border-b border-gray-200"><?= $escaper->escapeHtml(__('Date')) ?></th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider border-b border-gray-200"><?= $escaper->escapeHtml(__('Description')) ?></th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider whitespace-nowrap border-b border-gray-200"><?= $escaper->escapeHtml(__('Points')) ?></th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider whitespace-nowrap border-b border-gray-200"><?= $escaper->escapeHtml(__('Balance')) ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($transactions as $txn): ?>
                <?php $delta = (int) $txn->getPointsDelta(); ?>
                <tr class="border-b border-gray-200 transition duration-150">
                    <td class="px-4 py-3 text-gray-500 whitespace-nowrap"><?= $escaper->escapeHtml($block->formatDate($txn->getCreatedAt())) ?></td>
                    <td class="px-4 py-3 text-gray-800"><?= $escaper->escapeHtml($txn->getComment() ?: $txn->getActionCode()) ?></td>
                    <td class="px-4 py-3 text-right font-semibold">
                        <?php if ($delta >= 0): ?>
                        <span class="text-primary">+<?= /* @noEscape */ $delta ?></span>
                        <?php else: ?>
                        <span class="bg-red-50 px-2 py-1 rounded-sm text-xs font-bold" style="color:#ef4444"><?= /* @noEscape */ $delta ?></span>
                        <?php endif; ?>
                    </td>
                    <td class="px-4 py-3 text-right text-gray-700"><?= /* @noEscape */ (int) $txn->getPointsBalanceAfter() ?></td>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>
    <a href="<?= $escaper->escapeUrl($block->getUrl('rewardpoints/account/transactions')) ?>"
       class="inline-block mt-3 text-sm font-semibold text-primary underline">
        <?= $escaper->escapeHtml(__('View All Transactions →')) ?>
    </a>
    <?php endif; ?>
</div>

<!-- Social share -->
<?php if ($showSocial): ?>
<div class="pt-4 border-t border-gray-200">
    <h3 class="text-base font-semibold text-primary mb-3">
        <?= $escaper->escapeHtml(__('Share Your Rewards')) ?>
    </h3>
    <?php
    $shareUrl  = $block->getUrl('rewardpoints/account/index');
    $shareText = (string) __('I am earning reward points! Join me and start earning too.');
    ?>
    <div class="flex flex-wrap gap-2">
        <?php if ($viewModel->isFacebookEnabled()): ?>
        <a href="https://www.facebook.com/sharer/sharer.php?u=<?= $escaper->escapeUrl($shareUrl) ?>"
           target="_blank" rel="noopener noreferrer"
           class="btn inline-flex items-center gap-2 text-sm"
           style="background-color:#1877f2;color:#fff;border-color:#1877f2;">
            <svg class="w-4 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
            <?= $escaper->escapeHtml(__('Facebook')) ?>
        </a>
        <?php endif; ?>
        <?php if ($viewModel->isTwitterEnabled()): ?>
        <a href="https://twitter.com/intent/tweet?url=<?= $escaper->escapeUrl($shareUrl) ?>&text=<?= $escaper->escapeUrl($shareText) ?>"
           target="_blank" rel="noopener noreferrer"
           class="btn bg-gray-900 inline-flex items-center gap-2 text-sm text-white">
            <svg class="w-4 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <?= $escaper->escapeHtml(__('Twitter / X')) ?>
        </a>
        <?php endif; ?>
        <?php if ($viewModel->isPinterestEnabled()): ?>
        <a href="https://pinterest.com/pin/create/button/?url=<?= $escaper->escapeUrl($shareUrl) ?>&description=<?= $escaper->escapeUrl($shareText) ?>"
           target="_blank" rel="noopener noreferrer"
