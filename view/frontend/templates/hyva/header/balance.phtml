<?php
/**
 * Hyvä header / minicart balance display.
 * Uses Tailwind CSS utility classes — Hyvä coding standard.
 *
 * Injected into:
 *   - "cart-drawer.bottom" container (placement=minicart)
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Meetanshi\RewardPoints\ViewModel\Header\Balance $viewModel
 * @var \Magento\Framework\Escaper $escaper
 */

$viewModel = $block->getData('view_model');
$placement = (string) $block->getData('placement');

if (!$viewModel) {
    return;
}

if ($placement === 'minicart') {
    if (!$viewModel->isEnabledInMinicart()) {
        return;
    }
} else {
    if (!$viewModel->isEnabled()) {
        return;
    }
}
?>
<?php if ($placement === 'minicart'): ?>
<div class="border-t border-container px-4 py-2 text-sm">
    <a href="<?= $escaper->escapeUrl($viewModel->getAccountUrl()) ?>"
       title="<?= $escaper->escapeHtml(__('My Reward Points')) ?>"
       class="inline-flex items-center gap-1 text-primary hover:text-primary-darker no-underline">
        <span><?= $escaper->escapeHtml(__('Points:')) ?></span>
        <strong class="font-bold"><?= $escaper->escapeHtml($viewModel->getFormattedBalance()) ?></strong>
    </a>
</div>
<?php else: ?>
<a href="<?= $escaper->escapeUrl($viewModel->getAccountUrl()) ?>"
   title="<?= $escaper->escapeHtml(__('My Reward Points')) ?>"
   class="inline-flex items-center gap-1 text-sm text-primary hover:text-primary-darker no-underline whitespace-nowrap">
    <span><?= $escaper->escapeHtml(__('Points:')) ?></span>
    <strong class="font-bold"><?= $escaper->escapeHtml($viewModel->getFormattedBalance()) ?></strong>
</a>
<?php endif; ?>
