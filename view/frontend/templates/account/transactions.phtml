<script>
(function () {
    /* Intercept the filter form submit — bypass the SPA router */
    var form = document.getElementById('rph-filter-form');
    if (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            e.stopImmediatePropagation();
            var base = form.action.split('?')[0].replace(/\/+$/, '');
            var params = {};
            var s  = document.getElementById('rph-status').value;
            var df = document.getElementById('rph-date-from').value;
            var dt = document.getElementById('rph-date-to').value;
            if (s)  params.status    = s;
            if (df) params.date_from = df;
            if (dt) params.date_to   = dt;
            var qs = Object.keys(params).map(function (k) {
                return encodeURIComponent(k) + '=' + encodeURIComponent(params[k]);
            }).join('&');
            window.location.href = base + (qs ? '?' + qs : '');
        });
    }
}());
</script>
