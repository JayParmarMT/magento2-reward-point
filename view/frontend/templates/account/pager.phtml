<?php
/**
 * Custom pager template for the Reward Points transactions page.
 *
 * @var \Magento\Theme\Block\Html\Pager $block
 * @var \Magento\Framework\Escaper $escaper
 */
if (!$block->getCollection() || !$block->getCollection()->getSize()) {
    return;
}
if ($block->getLastPageNum() <= 1) {
    return;
}
$current = (int) $block->getCurrentPage();
$last    = (int) $block->getLastPageNum();
?>
<nav class="rph-pager" aria-label="<?= $escaper->escapeHtmlAttr(__('Pagination')) ?>">

    <?php if (!$block->isFirstPage()): ?>
    <a href="<?= $escaper->escapeUrl($block->getPreviousPageUrl()) ?>"
       aria-label="<?= $escaper->escapeHtmlAttr(__('Previous')) ?>">&#8249;</a>
    <?php else: ?>
    <span style="opacity:.35;cursor:default;">&#8249;</span>
    <?php endif; ?>

    <?php if ($block->canShowFirst()): ?>
        <a href="<?= $escaper->escapeUrl($block->getFirstPageUrl()) ?>">1</a>
        <?php if ($block->canShowPreviousJump()): ?>
        <span class="dots">…</span>
        <?php endif; ?>
    <?php endif; ?>

    <?php foreach ($block->getFramePages() as $page): ?>
        <?php if ($block->isPageCurrent($page)): ?>
        <span class="current"><?= /* @noEscape */ (int) $page ?></span>
        <?php else: ?>
        <a href="<?= $escaper->escapeUrl($block->getPageUrl($page)) ?>"><?= (int) $page ?></a>
        <?php endif; ?>
    <?php endforeach; ?>

    <?php if ($block->canShowLast()): ?>
        <?php if ($block->canShowNextJump()): ?>
        <span class="dots">…</span>
        <?php endif; ?>
        <a href="<?= $escaper->escapeUrl($block->getLastPageUrl()) ?>"><?= $last ?></a>
    <?php endif; ?>

    <?php if (!$block->isLastPage()): ?>
    <a href="<?= $escaper->escapeUrl($block->getNextPageUrl()) ?>"
       aria-label="<?= $escaper->escapeHtmlAttr(__('Next')) ?>">&#8250;</a>
    <?php else: ?>
    <span style="opacity:.35;cursor:default;">&#8250;</span>
    <?php endif; ?>

</nav>
