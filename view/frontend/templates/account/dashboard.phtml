<script>
(function () {
    'use strict';
    var form = document.getElementById('reward-points-settings-form');
    if (!form) return;

    form.addEventListener('submit', function (e) {
        e.preventDefault();
        var msgEl = document.getElementById('rp-settings-message');
        var data = new URLSearchParams(new FormData(form));

        fetch(form.getAttribute('action'), {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
            body: data
        })
        .then(function (r) { return r.json(); })
        .then(function (response) {
            var cls = response.success ? 'rp-message--success' : 'rp-message--error';
            var el = document.createElement('div');
            el.className = 'rp-message ' + cls;
            el.textContent = response.message;
            msgEl.innerHTML = '';
            msgEl.appendChild(el);
            setTimeout(function () { el.style.display = 'none'; }, 3000);
        })
        .catch(function () {
            var el = document.createElement('div');
            el.className = 'rp-message rp-message--error';
            el.textContent = 'An error occurred. Please try again.';
            msgEl.innerHTML = '';
            msgEl.appendChild(el);
        });
    });
}());
</script>
