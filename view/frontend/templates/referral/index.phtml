<script>
(function () {
    'use strict';

    function copyToClipboard(text, btn, successText) {
        var original = btn.textContent;
        var done = function () {
            btn.textContent = successText;
            setTimeout(function () { btn.textContent = original; }, 2000);
        };
        if (navigator.clipboard) {
            navigator.clipboard.writeText(text).then(done);
        } else {
            var el = document.createElement('textarea');
            el.value = text;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
            done();
        }
    }

    var copyCodeBtn = document.getElementById('rref-copy-code-btn');
    if (copyCodeBtn) {
        copyCodeBtn.addEventListener('click', function () {
            var codeEl = document.getElementById('rref-code-text');
            if (codeEl) {
                copyToClipboard(codeEl.textContent.trim(), copyCodeBtn, '<?= $escaper->escapeJs(__('Code Copied!')) ?>');
            }
        });
    }

    var copyLinkBtn = document.getElementById('rref-copy-link-btn');
    if (copyLinkBtn) {
        copyLinkBtn.addEventListener('click', function () {
            var urlInput = document.getElementById('rref-url-input');
            var feedback = document.getElementById('rref-copy-feedback');
            if (urlInput) {
                copyToClipboard(urlInput.value, copyLinkBtn, '<?= $escaper->escapeJs(__('Link Copied!')) ?>');
            }
            if (feedback) {
                feedback.style.display = 'inline';
                setTimeout(function () { feedback.style.display = 'none'; }, 2000);
            }
        });
    }

    var form = document.getElementById('rref-invite-form');
    if (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            var btn     = document.getElementById('rref-submit-btn');
            var success = document.getElementById('rref-msg-success');
            var error   = document.getElementById('rref-msg-error');

            success.style.display = 'none';
            error.style.display   = 'none';
            btn.disabled = true;
            btn.textContent = '<?= $escaper->escapeJs(__('Sending…')) ?>';

            var data = new URLSearchParams(new FormData(form));

            fetch(form.getAttribute('action'), {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
                body: data
            })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                var extra = (res.errors && res.errors.length) ? ' ' + res.errors.join(' ') : '';
                if (res.success) {
                    success.textContent = res.message + extra;
                    success.style.display = 'block';
                    var emails  = document.getElementById('rref-emails');
                    var message = document.getElementById('rref-message');
                    if (emails)  { emails.value  = ''; }
                    if (message) { message.value = ''; }
                } else {
                    error.textContent = res.message + extra;
                    error.style.display = 'block';
                }
            })
            .catch(function () {
                error.textContent = '<?= $escaper->escapeJs(__('An error occurred. Please try again.')) ?>';
                error.style.display = 'block';
            })
            .finally(function () {
                btn.disabled = false;
                btn.textContent = '<?= $escaper->escapeJs(__('Send Invitations')) ?>';
            });
        });
    }
}());
</script>
