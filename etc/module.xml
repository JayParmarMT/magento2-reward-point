<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Module/etc/module.xsd">
    <module name="Meetanshi_RewardPoints" setup_version="1.0.0">
        <sequence>
            <module name="Magento_Customer"/>
            <module name="Magento_Sales"/>
            <module name="Magento_SalesRule"/>
            <module name="Magento_CatalogRule"/>
            <module name="Magento_Quote"/>
            <module name="Magento_Checkout"/>
            <module name="Magento_Newsletter"/>
            <module name="Magento_Review"/>
            <!-- Hyvä Theme: soft dependency — layout XMLs with hyva_ handle prefix
                 are only activated when Hyva_Theme is present and loaded.
                 The module functions fully on Luma without this dependency. -->
            <module name="Hyva_Theme"/>
        </sequence>
    </module>
</config>
