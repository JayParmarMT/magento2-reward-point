<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Meetanshi_RewardPoints::reward_points" title="Reward Points" sortOrder="100">
                    <resource id="Meetanshi_RewardPoints::transactions" title="Transactions" sortOrder="10"/>
                    <resource id="Meetanshi_RewardPoints::earning" title="Earning" sortOrder="20">
                        <resource id="Meetanshi_RewardPoints::earning_rate" title="Earning Rates" sortOrder="10"/>
                        <resource id="Meetanshi_RewardPoints::catalog_rule" title="Catalog Earning Rules" sortOrder="20"/>
                        <resource id="Meetanshi_RewardPoints::cart_rule" title="Cart Earning Rules" sortOrder="30"/>
                        <resource id="Meetanshi_RewardPoints::behavior_rule" title="Behavior Earning Rules" sortOrder="40"/>
                    </resource>
                    <resource id="Meetanshi_RewardPoints::spending" title="Spending" sortOrder="30">
                        <resource id="Meetanshi_RewardPoints::spending_rate" title="Spending Rates" sortOrder="10"/>
                        <resource id="Meetanshi_RewardPoints::spending_rule" title="Cart Spending Rules" sortOrder="20"/>
                    </resource>
                    <resource id="Meetanshi_RewardPoints::referral_rule" title="Referral Rules" sortOrder="40"/>
                    <resource id="Meetanshi_RewardPoints::referral_invitation" title="Referral Invitations" sortOrder="50"/>
                    <resource id="Meetanshi_RewardPoints::tier" title="Tiers" sortOrder="60"/>
                    <resource id="Meetanshi_RewardPoints::report" title="Reports" sortOrder="70"/>
                    <resource id="Meetanshi_RewardPoints::import" title="Import" sortOrder="80"/>
                    <resource id="Meetanshi_RewardPoints::export" title="Export" sortOrder="90"/>
                    <resource id="Meetanshi_RewardPoints::config" title="Configuration" sortOrder="100"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
