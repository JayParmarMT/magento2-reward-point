<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">

    <!-- Admin: customer save — persist reward settings -->
    <event name="adminhtml_customer_prepare_save">
        <observer name="meetanshi_rewardpoints_save_customer_reward"
                  instance="Meetanshi\RewardPoints\Observer\SaveCustomerRewardSettingsObserver"/>
    </event>

    <!-- Custom: gate to disable earning per-customer -->
    <event name="meetanshi_rewardpoints_before_earn">
        <observer name="meetanshi_rewardpoints_disable_earning_check"
                  instance="Meetanshi\RewardPoints\Observer\DisableEarningForCustomerObserver"/>
    </event>

    <!-- Track last login for inactivity bonus -->
    <event name="customer_login">
        <observer name="meetanshi_rewardpoints_customer_login"
                  instance="Meetanshi\RewardPoints\Observer\CustomerLoginObserver"/>
    </event>

    <!-- Send email when balance changes -->
    <event name="meetanshi_rewardpoints_balance_changed">
        <observer name="meetanshi_rewardpoints_send_balance_email"
                  instance="Meetanshi\RewardPoints\Observer\SendBalanceUpdateEmailObserver"/>
    </event>

    <!-- Copy reward points data from quote to order BEFORE the order is persisted -->
    <event name="sales_model_service_quote_submit_before">
        <observer name="meetanshi_rewardpoints_quote_submit_before"
                  instance="Meetanshi\RewardPoints\Observer\QuoteSubmitBeforeObserver"/>
    </event>

    <!-- Create spend_order transaction after checkout -->
    <event name="checkout_submit_all_after">
        <observer name="meetanshi_rewardpoints_checkout_submit_all_after"
                  instance="Meetanshi\RewardPoints\Observer\CheckoutSubmitAllAfterObserver"/>
    </event>

    <!-- Earn points when invoice is paid -->
    <event name="sales_order_invoice_pay">
        <observer name="meetanshi_rewardpoints_invoice_pay"
                  instance="Meetanshi\RewardPoints\Observer\SalesOrderInvoicePayObserver"/>
    </event>

    <!-- Order save: earn on complete, handle referral reward, sell-by-points deduction -->
    <event name="sales_order_save_after">
        <observer name="meetanshi_rewardpoints_order_save"
                  instance="Meetanshi\RewardPoints\Observer\SalesOrderSaveAfterObserver"/>
        <observer name="meetanshi_rewardpoints_sales_order_complete_referral"
                  instance="Meetanshi\RewardPoints\Observer\SalesOrderCompleteObserver"/>
        <observer name="meetanshi_rewardpoints_sell_by_points_complete"
                  instance="Meetanshi\RewardPoints\Observer\SellByPointsOrderCompleteObserver"/>
    </event>

    <!-- Earn points when shipment is saved -->
    <event name="sales_order_shipment_save_after">
        <observer name="meetanshi_rewardpoints_shipment_save"
                  instance="Meetanshi\RewardPoints\Observer\SalesOrderShipmentSaveAfterObserver"/>
    </event>

    <!-- Handle refund: cancel or restore earned/spent points -->
    <event name="sales_order_creditmemo_save_after">
        <observer name="meetanshi_rewardpoints_creditmemo_save"
                  instance="Meetanshi\RewardPoints\Observer\CreditmemoSaveAfterObserver"/>
    </event>

    <!-- Track referral code during registration -->
    <event name="customer_register_success">
        <observer name="meetanshi_rewardpoints_register_referral"
                  instance="Meetanshi\RewardPoints\Observer\CustomerRegisterSuccessObserver"/>
    </event>

    <!-- Notify customer of tier change -->
    <event name="meetanshi_rewardpoints_tier_changed">
        <observer name="meetanshi_rewardpoints_tier_changed_notify"
                  instance="Meetanshi\RewardPoints\Observer\TierChangedObserver"/>
    </event>

    <!-- Rebuild catalog rule product index after a catalog rule is saved -->
    <event name="meetanshi_rewardpoints_catalog_rule_save_after">
        <observer name="meetanshi_rewardpoints_catalog_rule_reindex"
                  instance="Meetanshi\RewardPoints\Observer\CatalogRuleSaveAfterObserver"/>
    </event>

    <!-- Auto-apply maximum points when isUseMaxByDefault is enabled -->
    <event name="checkout_cart_save_after">
        <observer name="meetanshi_rewardpoints_auto_apply_max_points"
                  instance="Meetanshi\RewardPoints\Observer\AutoApplyMaxPointsObserver"/>
    </event>

</config>
