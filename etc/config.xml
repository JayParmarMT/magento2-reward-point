<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <meetanshi_rewardpoints>
            <general>
                <enabled>0</enabled>
                <label>Reward Points</label>
                <point_label>point</point_label>
                <point_label_plural>points</point_label_plural>
                <point_label_position>after</point_label_position>
                <zero_point_label>0 points</zero_point_label>
                <show_point_icon>0</show_point_icon>
                <max_balance>0</max_balance>
                <redirect_after_login>0</redirect_after_login>
            </general>
            <landing_page>
                <show_footer_link>0</show_footer_link>
                <footer_label>Reward Points</footer_label>
            </landing_page>
            <highlight>
                <show_in_cart>0</show_in_cart>
                <show_on_checkout>0</show_on_checkout>
                <show_on_product>0</show_on_product>
                <show_on_category>0</show_on_category>
                <show_for_guests>0</show_for_guests>
                <highlight_text_color>#000000</highlight_text_color>
            </highlight>
            <earning>
                <rounding_method>normal</rounding_method>
                <earn_from_tax>0</earn_from_tax>
                <earn_from_shipping>0</earn_from_shipping>
                <point_refund>1</point_refund>
                <point_holding_days>0</point_holding_days>
                <earn_from_coupon_orders>1</earn_from_coupon_orders>
                <calculation_type>after_tax</calculation_type>
                <earn_after_invoice>1</earn_after_invoice>
                <points_expire_after>0</points_expire_after>
            </earning>
            <spending>
                <min_points_per_order>0</min_points_per_order>
                <discount_label>Reward Points discount</discount_label>
                <max_points_type>fixed</max_points_type>
                <max_points_per_order>0</max_points_per_order>
                <spend_on_shipping>0</spend_on_shipping>
                <restore_spent_on_refund>1</restore_spent_on_refund>
                <use_max_by_default>0</use_max_by_default>
                <spend_from_coupon_orders>1</spend_from_coupon_orders>
                <apply_after_tax>0</apply_after_tax>
                <include_tax>0</include_tax>
            </spending>
            <display>
                <show_top_links>0</show_top_links>
                <hide_if_zero>0</hide_if_zero>
                <show_on_minicart>0</show_on_minicart>
                <show_on_cart>0</show_on_cart>
                <show_as_currency>0</show_as_currency>
                <show_max_for_configurable>0</show_max_for_configurable>
            </display>
            <email>
                <enable_notification>0</enable_notification>
                <subscribe_by_default>0</subscribe_by_default>
                <sender>general</sender>
                <expire_reminder_days>30,7,1</expire_reminder_days>
                <update_balance_template>meetanshi_rewardpoints_email_update_balance_template</update_balance_template>
                <expiration_template>meetanshi_rewardpoints_email_expiration_template</expiration_template>
                <tier_upgrade_template>meetanshi_rewardpoints_email_tier_upgrade_template</tier_upgrade_template>
                <tier_downgrade_template>meetanshi_rewardpoints_email_tier_downgrade_template</tier_downgrade_template>
                <birthday_template>meetanshi_rewardpoints_email_birthday_template</birthday_template>
            </email>
            <referral>
                <url_key_mode>param</url_key_mode>
                <code_prefix>code</code_prefix>
                <invitation_email_template>meetanshi_rewardpoints_referral_invitation_email_template</invitation_email_template>
                <api_invitation_email_template>meetanshi_rewardpoints_referral_api_invitation_email_template</api_invitation_email_template>
            </referral>
            <tier>
                <enabled>0</enabled>
                <basis>earned_points</basis>
                <period>0</period>
                <auto_demote>0</auto_demote>
                <progress_bg_color>#e5e7eb</progress_bg_color>
                <progress_color>#4f46e5</progress_color>
                <email_on_tier_change>1</email_on_tier_change>
            </tier>
            <social>
                <facebook_show_button>1</facebook_show_button>
                <facebook_show_count>0</facebook_show_count>
                <twitter_show_button>1</twitter_show_button>
                <pinterest_show_button>1</pinterest_show_button>
                <social_pages>referral,account,product</social_pages>
                <min_seconds_between_actions>0</min_seconds_between_actions>
            </social>
            <advanced>
                <round_down>0</round_down>
                <force_apply_styles>0</force_apply_styles>
            </advanced>
            <hyva>
                <enabled>1</enabled>
            </hyva>
        </meetanshi_rewardpoints>
    </default>
</config>
